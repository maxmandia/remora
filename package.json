{
  "name": "remora",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm dev:services && pnpm -r --parallel --filter @remora/web --filter @remora/backend --filter @remora/desktop dev",
    "dev:services": "docker compose up -d postgres temporal",
    "dev:services:down": "docker compose stop postgres temporal",
    "dev:web": "pnpm --filter @remora/web dev",
    "dev:backend": "pnpm dev:services && pnpm --filter @remora/backend dev",
    "dev:http": "pnpm --filter @remora/backend dev:http",
    "dev:worker": "pnpm dev:services && pnpm --filter @remora/backend dev:worker",
    "dev:desktop": "pnpm --filter @remora/desktop dev",
    "package:desktop": "pnpm --filter @remora/desktop package",
    "make:desktop": "pnpm --filter @remora/desktop make",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @remora/backend db:generate",
    "db:migrate": "pnpm --filter @remora/backend db:migrate",
    "db:reset": "pnpm --filter @remora/backend db:reset"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
