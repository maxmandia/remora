{
  "name": "remora",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm dev:services && (pnpm run dev:ngrok & pnpm -r --parallel --filter @remora/web --filter @remora/backend --filter @remora/desktop dev & wait)",
    "dev:services": "docker compose up -d postgres temporal",
    "dev:services:down": "docker compose stop postgres temporal",
    "dev:ngrok": "mkdir -p .logs && ngrok http --url=treefrog-fancy-inherently.ngrok-free.app 4000 --log=false > .logs/ngrok.log 2>&1",
    "dev:web": "pnpm --filter @remora/web dev",
    "dev:backend": "pnpm dev:services && pnpm --filter @remora/backend dev",
    "dev:http": "pnpm --filter @remora/backend dev:http",
    "dev:worker": "pnpm dev:services && pnpm --filter @remora/backend dev:worker",
    "dev:desktop": "pnpm --filter @remora/desktop dev",
    "package:desktop": "pnpm --filter @remora/desktop package",
    "package:desktop:nightly": "pnpm --filter @remora/desktop package:nightly",
    "package:desktop:stable": "pnpm --filter @remora/desktop package:stable",
    "make:desktop": "pnpm --filter @remora/desktop make",
    "make:desktop:nightly": "pnpm --filter @remora/desktop make:nightly",
    "make:desktop:stable": "pnpm --filter @remora/desktop make:stable",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "db:check": "pnpm --filter @remora/backend db:check",
    "db:generate": "pnpm --filter @remora/backend db:generate",
    "db:migrate": "pnpm --filter @remora/backend db:migrate",
    "db:reset": "pnpm --filter @remora/backend db:reset",
    "db:seed": "pnpm --filter @remora/backend db:seed",
    "model:validate": "pnpm --filter @remora/backend model:validate",
    "model:plan": "pnpm --filter @remora/backend model:plan",
    "model:generate-migration": "pnpm --filter @remora/backend model:generate-migration",
    "model:verify": "pnpm --filter @remora/backend model:verify",
    "seo-models:validate": "pnpm --filter @remora/web seo-models:validate",
    "db:rands": "pnpm db:reset && pnpm db:seed",
    "prepare": "husky"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
