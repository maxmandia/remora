{
  "name": "@remora/backend",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "dev": "pnpm run dev:http & pnpm run dev:worker & wait",
    "dev:http": "tsx watch --env-file-if-exists=../../.env src/http/index.ts",
    "dev:worker": "tsx watch --env-file-if-exists=../../.env src/worker/index.ts",
    "start": "pnpm run start:http",
    "start:http": "tsx --env-file-if-exists=../../.env src/http/index.ts",
    "start:worker": "tsx --env-file-if-exists=../../.env src/worker/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "node ./scripts/reset.mjs && drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "model:validate": "tsx scripts/model-catalog.ts validate",
    "model:plan": "tsx scripts/model-catalog.ts plan",
    "model:generate-migration": "tsx scripts/model-catalog.ts generate-migration",
    "model:verify": "tsx scripts/model-catalog.ts verify"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/lib-storage": "^3.1065.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "@better-auth/drizzle-adapter": "^1.6.13",
    "@better-auth/electron": "^1.6.13",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/core": "1.30.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.57.2",
    "@opentelemetry/resources": "1.30.1",
    "@opentelemetry/sdk-trace-base": "1.30.1",
    "@opentelemetry/sdk-trace-node": "1.30.1",
    "@remora/domain": "workspace:*",
    "@remora/env": "workspace:*",
    "@remora/realtime": "workspace:*",
    "@remora/utils": "workspace:*",
    "@sentry/node": "10.63.0",
    "@sentry/opentelemetry": "10.63.0",
    "@temporalio/activity": "1.17.2",
    "@temporalio/client": "1.17.2",
    "@temporalio/interceptors-opentelemetry": "1.17.2",
    "@temporalio/worker": "1.17.2",
    "@temporalio/workflow": "1.17.2",
    "@trpc/server": "^11.17.0",
    "better-auth": "^1.6.13",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "mixpanel": "0.22.0",
    "openai": "^6.46.0",
    "pino": "10.3.1",
    "postgres": "^3.4.7",
    "stripe": "^22.2.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "1.30.1",
    "@temporalio/testing": "1.17.2",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "4.1.7"
  }
}
