{
  "name": "@remora/desktop",
  "productName": "Remora",
  "description": "Desktop application for image and video generation.",
  "version": "0.3.0",
  "private": true,
  "type": "commonjs",
  "main": ".vite/main/main.js",
  "scripts": {
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "package:nightly": "DESKTOP_CHANNEL=nightly electron-forge package",
    "package:stable": "DESKTOP_CHANNEL=stable electron-forge package",
    "make": "electron-forge make",
    "make:dmg": "node scripts/make-dmg.mjs",
    "make:nightly": "railway run --environment staging --service backend-http-Fqh5 env DESKTOP_CHANNEL=nightly SENTRY_ENVIRONMENT=staging electron-forge make",
    "make:stable": "railway run --environment production --service backend-http-Fqh5 env DESKTOP_CHANNEL=stable SENTRY_ENVIRONMENT=production electron-forge make",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remora/domain": "workspace:*",
    "@remora/env": "workspace:*",
    "@remora/form": "workspace:*",
    "@remora/realtime": "workspace:*",
    "@remora/ui": "workspace:*",
    "@remora/utils": "workspace:*",
    "@sentry/electron": "7.15.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-router": "1.170.10",
    "@trpc/client": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "electron-squirrel-startup": "^1.0.1",
    "heic-to": "^1.5.2",
    "lucide-react": "0.545.0",
    "mixpanel-browser": "2.81.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@remora/backend": "workspace:*",
    "@sentry/vite-plugin": "5.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "6.0.2",
    "create-dmg": "8.1.0",
    "electron": "42.3.0",
    "jsdom": "28.1.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
