{
  "extends": "../../tsconfig.base.json",
  "include": [
    "forge.config.ts",
    "vite.*.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist/types",
    "types": ["node", "vite/client"]
  }
}
